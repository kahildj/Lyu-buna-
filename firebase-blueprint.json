{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "customerUid": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["telebirr", "cbe"] },
        "paymentScreenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "preparing", "completed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "items", "totalAmount", "paymentMethod", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
